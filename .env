# Web Call Environment Configuration
# Copy this file to .env and modify as needed

# Backend configuration
PUBLIC_BASE_URL=http://localhost:5173

# Frontend ICE configuration
# This JSON will be embedded into the frontend build
# Format: single-line JSON array of ICE servers
# Using external STUN/TURN server
VITE_ICE_JSON=[{"urls":["stun:20.80.101.0:3478"]},{"urls":["turn:20.80.101.0:3478?transport=udp","turn:20.80.101.0:3478?transport=tcp"],"username":"testuser","credential":"testpassword"}]

# Alternative: Completely autonomous mode (TURN only, no STUN)
# VITE_ICE_JSON=[{"urls":["turn:localhost:3478?transport=udp"],"username":"user","credential":"secret"}]
# VITE_ICE_TRANSPORT_POLICY=relay

# ICE transport policy: "all" (default) or "relay" (TURN-only)
VITE_ICE_TRANSPORT_POLICY=all

# Optional: Force H.264 codec for better compatibility
VITE_FORCE_H264=false
PUBLIC_BASE_URL=http://localhost:5173
VITE_API_BASE=
VITE_WS_BASE=
